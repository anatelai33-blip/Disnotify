generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model JoinEvent {
  id         Int      @id @default(autoincrement())
  userId     String
  username   String
  serverId   String
  serverName String
  joinedAt   DateTime @default(now())
  notified   Boolean  @default(false)

  @@index([userId, serverId])
}
