{
"name": "disnotify-pro",
"version": "1.0.0",
"type": "module",
"description": "Discord bot for real-time member join notifications",
"main": "src/index.js",
"scripts": {
 "start": "node src/index.js",
 "start:all": "concurrently \"node src/index.js\" \"node src/dashboard/server.js\"",
 "dev": "node --watch src/index.js",
 "setup": "prisma generate && prisma db push"
},
"dependencies": {
 "@prisma/client": "^5.8.0",
 "concurrently": "^8.2.2",
 "discord.js": "^14.14.1",
 "dotenv": "^16.3.1",
 "express": "^4.18.2",
 "express-session": "^1.18.0",
 "winston": "^3.11.0",
 "winston-daily-rotate-file": "^4.7.1"
},
"devDependencies": {
 "prisma": "^5.8.0"
},
"engines": {
 "node": ">=18.0.0"
}
}
